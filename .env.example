# ==========================================
# 环境变量配置 - 复制此文件为 .env.local 并填写实际值
# ==========================================

# ==================== 必需配置 ====================

# DeepSeek API (文本生成) - 必填
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== 图片生成配置 ====================
# 腾讯混元 (图片生成)
CONTENT_API_KEY=your_tencent_hunyuan_api_key
CONTENT_API_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
IMAGE_API_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# ==================== 数据库配置 ====================
# Supabase 数据库 (历史记录云端存储，可选)
COZE_SUPABASE_URL=your_supabase_project_url
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==================== 搜索配置 (可选) ====================
# SerpAPI (热点搜索)
# SERP_API_KEY=your_serp_api_key

# Bing搜索 (备用)
# BING_API_KEY=your_bing_api_key
